  "keyFeatures": [
    "100x faster random access reads vs Apache Parquet",
    "Zero-copy Apache Arrow integration",
    "Pluggable encoding system (FastLanes, FSST, ALP, BtrBlocks, RLE, dictionary, etc.)",
    "Stable columnar file format (.vortex) with O(1) column access via FlatBuffer metadata",
    "Native query engine integrations: DataFusion, DuckDB, Spark, Trino, Polars, Ray",
    "Multi-language support: Rust crate, Python (vortex-data on PyPI), Java/JVM with Spark connector",
    "Cascading compression with compute-on-compressed data (no decompress for many operations)",
    "Scan API with filter, projection, and limit pushdown over object storage"
  ],
  "publicApiSurface": [
    "vortex::array (ArrayRef, PrimitiveArray, StructArray, ChunkedArray, IntoArray)",
    "vortex::dtype (DType, Nullability)",
    "vortex::file (WriteOptionsSessionExt, OpenOptionsSessionExt, WriteStrategyBuilder)",
    "vortex::session (VortexSession, VortexSessionDefault)",
    "vortex::scan (ScanBuilder, with_filter, with_projection)",
    "vortex::compressor (BtrBlocksCompressor, BtrBlocksCompressorBuilder)",
    "vortex::encodings (alp, fastlanes, fsst, pco, runend, sparse, zigzag, zstd)",
    "vortex::ipc (IPC stream read/write)",
    "vortex::expr (gt, lit, root, select)",
    "Python: vortex.file (open, write), vortex.dataset, vortex.scan, vortex.expr, vortex.arrays",
